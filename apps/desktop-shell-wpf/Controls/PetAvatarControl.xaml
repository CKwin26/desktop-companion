<UserControl x:Class="DesktopCompanion.WpfHost.Controls.PetAvatarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="clr-namespace:DesktopCompanion.WpfHost.Models"
             mc:Ignorable="d"
             Width="210"
             Height="280"
             Background="Transparent"
             SnapsToDevicePixels="True">
  <UserControl.Resources>
    <DropShadowEffect x:Key="PetShadow"
                      BlurRadius="26"
                      Direction="270"
                      ShadowDepth="10"
                      Opacity="0.2"
                      Color="#3322363B" />

    <Style x:Key="MoodGlowStyle" TargetType="Ellipse">
      <Setter Property="Opacity" Value="0.34" />
      <Style.Triggers>
        <DataTrigger Binding="{Binding Mood}" Value="{x:Static models:PetMood.Focused}">
          <Setter Property="Opacity" Value="0.44" />
        </DataTrigger>
        <DataTrigger Binding="{Binding Mood}" Value="{x:Static models:PetMood.Concerned}">
          <Setter Property="Opacity" Value="0.52" />
        </DataTrigger>
        <DataTrigger Binding="{Binding Mood}" Value="{x:Static models:PetMood.Happy}">
          <Setter Property="Opacity" Value="0.48" />
        </DataTrigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="ThinkingHaloStyle" TargetType="Ellipse">
      <Setter Property="Visibility" Value="Collapsed" />
      <Setter Property="Opacity" Value="0" />
      <Style.Triggers>
        <DataTrigger Binding="{Binding IsAwaitingReply}" Value="True">
          <Setter Property="Visibility" Value="Visible" />
          <Setter Property="Opacity" Value="0.92" />
        </DataTrigger>
      </Style.Triggers>
    </Style>
  </UserControl.Resources>

  <Grid>
    <Grid.RenderTransform>
      <TranslateTransform x:Name="PetFloatTransform" />
    </Grid.RenderTransform>
    <Grid.Triggers>
      <EventTrigger RoutedEvent="Loaded">
        <BeginStoryboard>
          <Storyboard RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="PetFloatTransform"
                             Storyboard.TargetProperty="Y"
                             From="0"
                             To="-7"
                             Duration="0:0:2.6" />
          </Storyboard>
        </BeginStoryboard>
      </EventTrigger>

      <EventTrigger RoutedEvent="Loaded">
        <BeginStoryboard>
          <Storyboard RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="AvatarScaleTransform"
                             Storyboard.TargetProperty="ScaleX"
                             From="0.988"
                             To="1.014"
                             Duration="0:0:2.6" />
            <DoubleAnimation Storyboard.TargetName="AvatarScaleTransform"
                             Storyboard.TargetProperty="ScaleY"
                             From="1"
                             To="1.018"
                             Duration="0:0:2.6" />
            <DoubleAnimation Storyboard.TargetName="MoodGlowScaleTransform"
                             Storyboard.TargetProperty="ScaleX"
                             From="0.94"
                             To="1.08"
                             Duration="0:0:2.6" />
            <DoubleAnimation Storyboard.TargetName="MoodGlowScaleTransform"
                             Storyboard.TargetProperty="ScaleY"
                             From="0.94"
                             To="1.08"
                             Duration="0:0:2.6" />
          </Storyboard>
        </BeginStoryboard>
      </EventTrigger>

      <EventTrigger RoutedEvent="Loaded">
        <BeginStoryboard>
          <Storyboard RepeatBehavior="Forever">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ThinkingHalo"
                                           Storyboard.TargetProperty="Opacity">
              <SplineDoubleKeyFrame KeyTime="0:0:0" Value="0.15" />
              <SplineDoubleKeyFrame KeyTime="0:0:0.7" Value="0.88" />
              <SplineDoubleKeyFrame KeyTime="0:0:1.5" Value="0.28" />
              <SplineDoubleKeyFrame KeyTime="0:0:2.3" Value="0.78" />
              <SplineDoubleKeyFrame KeyTime="0:0:3.1" Value="0.15" />
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimation Storyboard.TargetName="ThinkingHaloRotateTransform"
                             Storyboard.TargetProperty="Angle"
                             From="0"
                             To="360"
                             Duration="0:0:5.5"
                             RepeatBehavior="Forever" />
          </Storyboard>
        </BeginStoryboard>
      </EventTrigger>
    </Grid.Triggers>

    <Ellipse Width="126"
             Height="24"
             VerticalAlignment="Bottom"
             HorizontalAlignment="Center"
             Margin="0,0,0,12"
             Fill="#2D22363B"
             Opacity="0.22">
      <Ellipse.Effect>
        <BlurEffect Radius="10" />
      </Ellipse.Effect>
    </Ellipse>

    <Ellipse x:Name="MoodGlow"
             Width="116"
             Height="116"
             HorizontalAlignment="Left"
             VerticalAlignment="Top"
             Margin="20,76,0,0"
             Fill="{Binding AccentTintBrush}"
             Style="{StaticResource MoodGlowStyle}">
      <Ellipse.RenderTransform>
        <ScaleTransform x:Name="MoodGlowScaleTransform"
                        CenterX="58"
                        CenterY="58" />
      </Ellipse.RenderTransform>
      <Ellipse.Effect>
        <BlurEffect Radius="16" />
      </Ellipse.Effect>
    </Ellipse>

    <Ellipse x:Name="ThinkingHalo"
             Width="44"
             Height="44"
             HorizontalAlignment="Right"
             VerticalAlignment="Top"
             Margin="0,26,18,0"
             Fill="{Binding AccentTintBrush}"
             Style="{StaticResource ThinkingHaloStyle}">
      <Ellipse.RenderTransform>
        <TransformGroup>
          <RotateTransform x:Name="ThinkingHaloRotateTransform"
                           CenterX="22"
                           CenterY="22" />
          <TranslateTransform X="0" Y="0" />
        </TransformGroup>
      </Ellipse.RenderTransform>
      <Ellipse.Effect>
        <BlurEffect Radius="10" />
      </Ellipse.Effect>
    </Ellipse>

    <Border Width="194"
            Height="258"
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            Background="Transparent">
      <Border.RenderTransform>
        <ScaleTransform x:Name="AvatarScaleTransform"
                        CenterX="97"
                        CenterY="129" />
      </Border.RenderTransform>

      <Grid>
        <Image Source="/Assets/Images/tuanzi-avatar.png"
               Stretch="Uniform"
               HorizontalAlignment="Center"
               VerticalAlignment="Top"
               RenderOptions.BitmapScalingMode="Fant">
          <Image.Effect>
            <DropShadowEffect BlurRadius="26"
                              Direction="270"
                              ShadowDepth="10"
                              Opacity="0.2"
                              Color="#3322363B" />
          </Image.Effect>
        </Image>

      </Grid>
    </Border>
  </Grid>
</UserControl>
