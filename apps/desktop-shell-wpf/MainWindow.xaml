<Window x:Class="DesktopCompanion.WpfHost.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:DesktopCompanion.WpfHost.Controls"
        mc:Ignorable="d"
        Title="Desktop Companion Pet"
        Width="596"
        Height="540"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        FontFamily="Microsoft YaHei UI"
        Loaded="OnLoaded">
  <Window.Resources>
    <DropShadowEffect x:Key="BubbleShadow"
                      BlurRadius="24"
                      Direction="270"
                      ShadowDepth="8"
                      Opacity="0.18"
                      Color="#2E22363B" />

    <Style x:Key="GhostButtonStyle" TargetType="Button">
      <Setter Property="Background" Value="#1022363B" />
      <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="10,6" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}"
                    CornerRadius="18">
              <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                Margin="{TemplateBinding Padding}" />
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="AccentButtonStyle"
           TargetType="Button"
           BasedOn="{StaticResource GhostButtonStyle}">
      <Setter Property="Background" Value="#3379B5AA" />
      <Setter Property="Foreground" Value="#FF2B6E64" />
    </Style>

    <Style x:Key="InvisiblePetButtonStyle" TargetType="Button">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <ContentPresenter />
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="ClickCatcherButtonStyle" TargetType="Button">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}" />
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="PanelTextBoxStyle" TargetType="TextBox">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
      <Setter Property="TextWrapping" Value="Wrap" />
      <Setter Property="AcceptsReturn" Value="False" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="CaretBrush" Value="{StaticResource InkBrush}" />
    </Style>

    <Style x:Key="SuggestionBubbleButtonStyle"
           TargetType="Button"
           BasedOn="{StaticResource GhostButtonStyle}">
      <Setter Property="Background" Value="#FFFDF9F4" />
      <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
      <Setter Property="Padding" Value="14,10" />
      <Setter Property="Margin" Value="0,0,0,8" />
      <Setter Property="Width" Value="160" />
      <Setter Property="HorizontalAlignment" Value="Left" />
      <Setter Property="HorizontalContentAlignment" Value="Left" />
      <Setter Property="BorderBrush" Value="#1679B5AA" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="16">
              <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                Margin="{TemplateBinding Padding}" />
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <ContextMenu x:Key="PetSettingsMenu"
                 Opened="OnPetSettingsMenuOpened">
      <MenuItem Header="在 VS Code 打开最近项目"
                Click="OnOpenRecentWorkspaceInVsCodeMenuClicked" />
      <MenuItem Header="查看 Codex 后端"
                Click="OnCodexBackendsMenuClicked" />
      <Separator />
      <MenuItem Header="人格内核">
        <MenuItem Header="Julie Zhuo"
                  Tag="balanced"
                  IsCheckable="True"
                  Click="OnKernelMenuClicked" />
        <MenuItem Header="Andy Grove"
                  Tag="operator"
                  IsCheckable="True"
                  Click="OnKernelMenuClicked" />
        <MenuItem Header="Shreyas Doshi"
                  Tag="research"
                  IsCheckable="True"
                  Click="OnKernelMenuClicked" />
        <MenuItem Header="Cal Newport"
                  Tag="focus"
                  IsCheckable="True"
                  Click="OnKernelMenuClicked" />
        <MenuItem Header="David Allen"
                  Tag="clarify"
                  IsCheckable="True"
                  Click="OnKernelMenuClicked" />
        <MenuItem Header="你自己（本地蒸馏）"
                  Tag="self"
                  IsCheckable="True"
                  Click="OnKernelMenuClicked" />
      </MenuItem>
      <MenuItem Header="查看当前人格"
                Click="OnKernelSummaryMenuClicked" />
      <Separator />
      <MenuItem Header="权限设置"
                Click="OnPermissionsMenuClicked" />
      <MenuItem Header="查看当前权限"
                Click="OnPermissionSummaryMenuClicked" />
      <Separator />
      <MenuItem Header="清空已授权目录"
                Click="OnClearWorkspaceSourcesMenuClicked" />
      <MenuItem Header="重新首次引导"
                Click="OnRestartOnboardingMenuClicked" />
      <Separator />
      <MenuItem Header="退出团子"
                Click="OnExitMenuClicked" />
    </ContextMenu>
  </Window.Resources>

  <Grid PreviewMouseLeftButtonDown="OnDragSurfaceMouseLeftButtonDown"
        PreviewMouseMove="OnDragSurfaceMouseMove"
        PreviewMouseLeftButtonUp="OnDragSurfaceMouseLeftButtonUp">
    <Grid Width="596"
          Height="540"
          HorizontalAlignment="Right">
      <Canvas Width="596"
              Height="540"
              HorizontalAlignment="Right"
              VerticalAlignment="Top">
        <Grid x:Name="TaskPanel"
              Width="160"
              Canvas.Left="102"
              Canvas.Top="196"
              Visibility="Hidden"
              Opacity="0"
              IsHitTestVisible="False">
          <Grid.RenderTransform>
            <TranslateTransform x:Name="TaskPanelTransform" X="-12" />
          </Grid.RenderTransform>

          <StackPanel Width="160"
                      VerticalAlignment="Top">
            <ItemsControl ItemsSource="{Binding SuggestionBubbles}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <StackPanel />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Button Click="OnSuggestionBubbleClicked"
                          Tag="{Binding Text}"
                          Style="{StaticResource SuggestionBubbleButtonStyle}">
                    <TextBlock Text="{Binding Text}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               TextAlignment="Left"
                               TextWrapping="Wrap"
                               LineHeight="17" />
                  </Button>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Grid>

        <Button x:Name="ClosedShellClickCatcher"
                Width="300"
                Height="462"
                Canvas.Left="214"
                Canvas.Top="18"
                Background="#01FFFFFF"
                AutomationProperties.AutomationId="ClosedShellClickCatcher"
                AutomationProperties.Name="ClosedShellClickCatcher"
                Click="OnTogglePanelClicked"
                ContextMenu="{StaticResource PetSettingsMenu}"
                Style="{StaticResource ClickCatcherButtonStyle}" />

        <StackPanel x:Name="ReplyBubbleHost"
                    Width="244"
                    Canvas.Left="244"
                    Canvas.Top="18">
          <Border x:Name="ReplyBubble"
                  Width="244"
                  Height="112"
                  Padding="16,14,16,12"
                  CornerRadius="24"
                  Background="{StaticResource CreamBrush}"
                  BorderBrush="{StaticResource SoftBorderBrush}"
                  BorderThickness="1"
                  Effect="{StaticResource BubbleShadow}">
            <Grid>
              <ScrollViewer Margin="0,8,10,0"
                            VerticalScrollBarVisibility="Auto"
                            HorizontalScrollBarVisibility="Disabled">
                <TextBlock Text="{Binding WhisperLine}"
                           TextWrapping="Wrap"
                           FontSize="15"
                           FontWeight="SemiBold"
                           LineHeight="22"
                           Foreground="{StaticResource InkBrush}" />
              </ScrollViewer>
              <Thumb x:Name="ReplyBubbleResizeThumb"
                     Width="16"
                     Height="16"
                     HorizontalAlignment="Right"
                     VerticalAlignment="Top"
                     Margin="0,6,6,0"
                     Cursor="SizeNESW"
                     DragDelta="OnReplyBubbleResizeDragDelta">
                <Thumb.Template>
                  <ControlTemplate TargetType="Thumb">
                    <Grid Width="16"
                          Height="16"
                          Background="Transparent">
                      <Path HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Stroke="#668A8F93"
                            StrokeThickness="1.4"
                            Data="M 0 8 L 8 0 M 4 12 L 12 4 M 8 16 L 16 8" />
                    </Grid>
                  </ControlTemplate>
                </Thumb.Template>
              </Thumb>
            </Grid>
          </Border>
          <Polygon HorizontalAlignment="Center"
                   Margin="0,-2,0,0"
                   Fill="{StaticResource CreamBrush}"
                   Points="0,0 18,0 9,12" />
        </StackPanel>

        <Button x:Name="PetToggleButton"
                Width="184"
                Height="212"
                Canvas.Left="274"
                Canvas.Top="138"
                AutomationProperties.AutomationId="PetToggleButton"
                AutomationProperties.Name="PetToggleButton"
                Click="OnTogglePanelClicked"
                ContextMenu="{StaticResource PetSettingsMenu}"
                Style="{StaticResource InvisiblePetButtonStyle}">
          <Viewbox Width="148"
                   Height="184"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Stretch="Uniform">
            <controls:PetAvatarControl IsHitTestVisible="False" />
          </Viewbox>
        </Button>

        <Border x:Name="ComposerBubble"
                Width="270"
                Visibility="Hidden"
                Opacity="0"
                Canvas.Left="230"
                Canvas.Top="378"
                Padding="14,12,14,14"
                CornerRadius="22"
                Background="#FFFFFFFF"
                BorderBrush="#3379B5AA"
                BorderThickness="1.5"
                Effect="{StaticResource BubbleShadow}">
            <StackPanel>
              <TextBlock Text="跟团子说一句"
                         FontSize="11"
                         FontWeight="SemiBold"
                         Foreground="{Binding AccentBrush}" />
              <Grid Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Grid>
                  <TextBox x:Name="QuickComposerTextBox"
                           AutomationProperties.AutomationId="QuickComposerTextBox"
                           AutomationProperties.Name="QuickComposerTextBox"
                           Text="{Binding ChatInput, UpdateSourceTrigger=PropertyChanged}"
                           KeyDown="OnNaturalInputKeyDown"
                           GotKeyboardFocus="OnQuickComposerFocused"
                           MinHeight="24"
                           IsEnabled="{Binding CanSendMessage}"
                           Style="{StaticResource PanelTextBoxStyle}" />
                  <TextBlock Text="直接说，比如：我现在有点乱 / 帮我盯住 pitch"
                             Margin="0,2,0,0"
                             FontSize="12"
                             Foreground="#8062767B"
                             IsHitTestVisible="False">
                    <TextBlock.Style>
                      <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding ChatInput}" Value="">
                            <Setter Property="Visibility" Value="Visible" />
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </TextBlock.Style>
                  </TextBlock>
                </Grid>

                <Button Grid.Column="1"
                        x:Name="SubmitInputButton"
                        AutomationProperties.AutomationId="SubmitInputButton"
                        AutomationProperties.Name="SubmitInputButton"
                        Margin="12,0,0,0"
                        Click="OnSubmitInputClicked"
                        Style="{StaticResource AccentButtonStyle}"
                        IsEnabled="{Binding CanSendMessage}"
                        Content="{Binding SendButtonText}" />
              </Grid>
            </StackPanel>
        </Border>
      </Canvas>
    </Grid>
  </Grid>
</Window>
