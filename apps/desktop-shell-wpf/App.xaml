<Application x:Class="DesktopCompanion.WpfHost.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
  <Application.Resources>
    <SolidColorBrush x:Key="CreamBrush" Color="#FFFDF7F0" />
    <SolidColorBrush x:Key="SoftBorderBrush" Color="#1E22363B" />
    <SolidColorBrush x:Key="InkBrush" Color="#FF22363B" />
    <SolidColorBrush x:Key="MutedBrush" Color="#FF62767B" />
    <LinearGradientBrush x:Key="PetBodyBrush" StartPoint="0.5,0" EndPoint="0.5,1">
      <GradientStop Offset="0" Color="#FFFFE8CD" />
      <GradientStop Offset="0.62" Color="#FFFFD89E" />
      <GradientStop Offset="1" Color="#FFFFC97C" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="PetEarBrush" StartPoint="0.5,0" EndPoint="0.5,1">
      <GradientStop Offset="0" Color="#FFFFE0C7" />
      <GradientStop Offset="1" Color="#FFF1B79A" />
    </LinearGradientBrush>
  </Application.Resources>
</Application>
